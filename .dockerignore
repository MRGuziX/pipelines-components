# Git history — contains commit metadata and potentially sensitive data
.git/

# Secrets and credentials
.env
.env.*
*.env
.envrc
*.pem
*.key
*.cert
*.crt
*.p12
*.pfx
secrets/
credentials/
kubeconfig
*.kubeconfig
.kube/

# Virtual environments — large and not needed for wheel build
.venv/
venv/
env/
ENV/

# Python build artefacts — avoid stale state polluting the wheel
__pycache__/
*.py[cod]
*.egg-info/
*.dist-info/
dist/
build/
*.whl
*.egg
MANIFEST
pip-wheel-metadata/

# Test and coverage outputs
.pytest_cache/
.coverage
.coverage.*
htmlcov/
coverage.xml
*.cover
.tox/
.nox/
.hypothesis/

# IDE and editor files
.idea/
.vscode/
*.iml
*.ipr
*.iws
*.swp
*.swo
*~
.DS_Store

# Docs and generated files
docs/
site/
generated_docs/

# CI configuration — not needed inside the image
.github/
.gitlab-ci*.yml

# Logs and temporary files
*.log
logs/
tmp/
temp/
.tmp/
.cache/
cache/

# Kubernetes / Terraform state — sensitive
*.tfstate
*.tfstate.*
.terraform/
*.tfvars

# Compiled KFP pipeline YAMLs — build artefacts, not source
*.compiled.yaml
component.yaml
pipeline.yaml
